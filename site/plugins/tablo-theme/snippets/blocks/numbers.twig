<div class="grid grid-cols-fill-64 gap-8">
  {% for item in block.items.toStructure %}
  <article class="text-2xl max-w-copy">
    <h3 class="{{ clsx('tracking-tight', {
  size3xl: 'text-3xl',
  size4xl: 'text-4xl',
  size5xl: 'text-5xl',
  size6xl: 'text-6xl',
  size7xl: 'text-7xl',
}[block.size.value]) }}">{{ item.number }}</h3>
    {%~ if item.description.isNotEmpty %}
    <div class="text-2xl text-current/50">
      <p>{{ item.description }}</p>
    </div>
    {%~ endif %}
  </article>
  {% endfor %}
</div>
