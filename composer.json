{
  "type": "project",
  "require": {
    "getkirby/cms": "^5.0",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "symfony/var-dumper": "^7.0",
    "lemmon/cl": "^1.1"
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S localhost:8000 kirby/router.php"
    ]
  }
}
